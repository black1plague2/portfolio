import * as THREE from 'three';
import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';
import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
import { OBJLoader } from 'three/examples/jsm/loaders/OBJLoader.js';
import { FBXLoader } from 'three/examples/jsm/loaders/FBXLoader.js';
import { EffectComposer } from 'three/examples/jsm/postprocessing/EffectComposer.js';
import { RenderPass } from 'three/examples/jsm/postprocessing/RenderPass.js';
import { UnrealBloomPass } from 'three/examples/jsm/postprocessing/UnrealBloomPass.js';
import { FilmPass } from 'three/examples/jsm/postprocessing/FilmPass.js';
import { gsap } from 'gsap';
import GUI from 'lil-gui';

// Loading Brain 3D Manager
class LoadingBrain3D {
    constructor() {
        this.scene = null;
        this.camera = null;
        this.renderer = null;
        this.brainModel = null;
        this.colorProgress = 0;
        this.targetProgress = 0;
        this.fbxLoader = new FBXLoader();
        this.animationId = null;
        this.brainParts = [];
        this.neuralParticles = null;
        this.regenerationParticles = null;
        this.regenerationActive = false;
    }

    init() {
        const container = document.getElementById('loading-brain-3d');
        if (!container) {
            console.warn('Loading brain container not found');
            return;
        }

        // Setup scene
        this.scene = new THREE.Scene();
        
        // Setup camera
        this.camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
        this.camera.position.set(0, 0, 12);
        
        // Setup renderer
        this.renderer = new THREE.WebGLRenderer({ 
            alpha: true, 
            antialias: true 
        });
        this.renderer.setSize(400, 400);
        this.renderer.setClearColor(0x000000, 0);
        container.appendChild(this.renderer.domElement);

        // Setup lighting
        const ambientLight = new THREE.AmbientLight(0x404040, 0.4);
        this.scene.add(ambientLight);
        
        const directionalLight = new THREE.DirectionalLight(0xffffff, 0.8);
        directionalLight.position.set(5, 5, 5);
        this.scene.add(directionalLight);

        // Load brain model asynchronously
        this.loadBrainModel().then(() => {
            console.log('Loading brain FBX model loaded successfully');
        }).catch((error) => {
            console.warn('FBX model not found, creating procedural brain:', error);
            this.createProceduralBrain();
        });

        this.createNeuralParticles();
        this.createRegenerationParticles();
        this.startImmediateRegeneration();
        this.animate();
    }

    loadBrainModel() {
        return new Promise((resolve, reject) => {
            this.fbxLoader.load(
                '/BRAIN.fbx',
                (model) => {
                    this.brainModel = model;
                    model.scale.setScalar(0.05);
                    model.position.set(0, 0, 0);
                    
                    // Process model parts for animation
                    this.brainParts = [];
                    model.traverse((child) => {
                        if (child.isMesh) {
                            // Store original properties
                            child.userData.originalPosition = child.position.clone();
                            child.userData.originalScale = child.scale.clone();
                            child.userData.originalColor = child.material.color.clone();
                            child.userData.targetColor = new THREE.Color(0xffff00);
                            child.userData.regenerationStarted = false;
                            
                            // Start scattered
                            child.position.add(new THREE.Vector3(
                                (Math.random() - 0.5) * 10,
                                (Math.random() - 0.5) * 10,
                                (Math.random() - 0.5) * 10
                            ));
                            child.scale.multiplyScalar(0.1);
                            child.material.opacity = 0;
                            child.material.transparent = true;
                            
                            this.brainParts.push(child);
                        }
                    });
                    
                    this.scene.add(model);
                    resolve(model);
                },
                undefined,
                (error) => {
                    console.log('Could not load FBX brain model:', error);
                    reject(error);
                }
            );
        });
    }

    createProceduralBrain() {
        const brainGroup = new THREE.Group();
        this.brainParts = [];

        // Create multiple brain-like segments
        for (let i = 0; i < 8; i++) {
            const geometry = new THREE.SphereGeometry(1 + Math.random() * 0.5, 16, 16);
            const material = new THREE.MeshPhongMaterial({
                color: 0x888888,
                transparent: true,
                opacity: 0
            });
            
            const mesh = new THREE.Mesh(geometry, material);
            
            // Position brain parts
            const angle = (i / 8) * Math.PI * 2;
            const radius = 1.5 + Math.random();
            mesh.userData.originalPosition = new THREE.Vector3(
                Math.cos(angle) * radius,
                (Math.random() - 0.5) * 2,
                Math.sin(angle) * radius
            );
            
            // Start scattered
            mesh.position.set(
                (Math.random() - 0.5) * 10,
                (Math.random() - 0.5) * 10,
                (Math.random() - 0.5) * 10
            );
            
            mesh.userData.originalScale = new THREE.Vector3(1, 1, 1);
            mesh.userData.originalColor = new THREE.Color(0x888888);
            mesh.userData.targetColor = new THREE.Color(0xffff00);
            mesh.userData.regenerationStarted = false;
            mesh.scale.setScalar(0.1);
            
            brainGroup.add(mesh);
            this.brainParts.push(mesh);
        }
        
        this.brainModel = brainGroup;
        this.scene.add(brainGroup);
    }

    createNeuralParticles() {
        const particleCount = 50;
        const geometry = new THREE.BufferGeometry();
        const positions = new Float32Array(particleCount * 3);
        
        for (let i = 0; i < particleCount; i++) {
            const i3 = i * 3;
            const radius = 2 + Math.random() * 1;
            const theta = Math.random() * Math.PI * 2;
            const phi = Math.random() * Math.PI;
            
            positions[i3] = radius * Math.sin(phi) * Math.cos(theta);
            positions[i3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
            positions[i3 + 2] = radius * Math.cos(phi);
        }
        
        geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        
        const material = new THREE.PointsMaterial({
            color: 0x00ffff,
            size: 0.1,
            transparent: true,
            opacity: 0,
            blending: THREE.AdditiveBlending
        });
        
        this.neuralParticles = new THREE.Points(geometry, material);
        this.scene.add(this.neuralParticles);
    }

    createRegenerationParticles() {
        const particleCount = 100;
        const geometry = new THREE.BufferGeometry();
        const positions = new Float32Array(particleCount * 3);
        
        for (let i = 0; i < particleCount; i++) {
            const i3 = i * 3;
            positions[i3] = (Math.random() - 0.5) * 10;
            positions[i3 + 1] = (Math.random() - 0.5) * 10;
            positions[i3 + 2] = (Math.random() - 0.5) * 10;
        }
        
        geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        
        const material = new THREE.PointsMaterial({
            color: 0xffaa00,
            size: 0.05,
            transparent: true,
            opacity: 0,
            blending: THREE.AdditiveBlending
        });
        
        this.regenerationParticles = new THREE.Points(geometry, material);
        this.scene.add(this.regenerationParticles);
    }

    startImmediateRegeneration() {
        if (!this.brainParts || this.brainParts.length === 0) return;
        
        this.brainParts.forEach((part, index) => {
            const delay = index * 0.1;
            this.startPartRegenerationImmediate(part, delay);
        });
        
        if (this.neuralParticles) {
            gsap.to(this.neuralParticles.material, { duration: 1, opacity: 0.6 });
        }
        if (this.regenerationParticles) {
            gsap.to(this.regenerationParticles.material, { duration: 1, opacity: 0.4 });
        }
        
        this.regenerationActive = true;
    }

    startPartRegenerationImmediate(part, delay) {
        setTimeout(() => {
            part.userData.regenerationStarted = true;
            
            gsap.to(part.position, {
                duration: 1.5,
                x: part.userData.originalPosition.x,
                y: part.userData.originalPosition.y,
                z: part.userData.originalPosition.z,
                ease: "back.out(1.2)"
            });
            
            gsap.to(part.scale, {
                duration: 1.5,
                x: part.userData.originalScale.x,
                y: part.userData.originalScale.y,
                z: part.userData.originalScale.z,
                ease: "back.out(1.2)"
            });
            
            gsap.to(part.material, {
                duration: 2,
                opacity: 0.8,
                ease: "power2.out"
            });
            
            part.material.userData = part.material.userData || {};
            part.material.userData.isRegenerating = true;
        }, delay * 1000);
    }

    updateProgress(progress) {
        this.targetProgress = Math.min(1, Math.max(0, progress));
        
        if (this.neuralParticles) {
            gsap.to(this.neuralParticles.material, { 
                duration: 0.5, 
                opacity: Math.min(0.8, progress * 1.2) 
            });
        }
        
        if (this.regenerationParticles) {
            gsap.to(this.regenerationParticles.material, { 
                duration: 0.5, 
                opacity: Math.min(0.6, progress * 1.5) 
            });
        }
    }

    animate() {
        if (!this.renderer || !this.scene || !this.camera) return;
        
        this.animationId = requestAnimationFrame(() => this.animate());
        
        this.colorProgress += (this.targetProgress - this.colorProgress) * 0.05;
        
        // Rotate brain model
        if (this.brainModel) {
            this.brainModel.rotation.y += 0.01;
            
            // Update brain colors during regeneration
            if (this.brainParts && this.brainParts.length > 0) {
                this.brainParts.forEach((part, index) => {
                    if (part.material && part.material.userData && part.material.userData.isRegenerating) {
                        const colorProgress = Math.min(1, part.material.opacity * 2);
                        const currentColor = part.userData.originalColor.clone().lerp(
                            part.userData.targetColor, 
                            colorProgress
                        );
                        part.material.color = currentColor;
                        
                        const time = Date.now() * 0.003;
                        const pulse = Math.sin(time + index) * 0.1 + 1;
                        part.material.emissive = currentColor.clone().multiplyScalar(0.3 * pulse);
                    }
                });
            }
        }
        
        // Animate particles
        if (this.neuralParticles) {
            this.neuralParticles.rotation.y += 0.005;
        }
        if (this.regenerationParticles) {
            this.regenerationParticles.rotation.x += 0.003;
            this.regenerationParticles.rotation.z += 0.002;
        }
        
        this.renderer.render(this.scene, this.camera);
    }

    dispose() {
        if (this.animationId) {
            cancelAnimationFrame(this.animationId);
            this.animationId = null;
        }
        
        if (this.renderer) {
            this.renderer.dispose();
        }
        
        // Clean up scene
        if (this.scene) {
            this.scene.traverse((child) => {
                if (child.geometry) child.geometry.dispose();
                if (child.material) {
                    if (Array.isArray(child.material)) {
                        child.material.forEach(mat => mat.dispose());
                    } else {
                        child.material.dispose();
                    }
                }
            });
        }
    }
}
